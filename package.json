{
  "name": "esphome-lvgl-editor",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Web preview & visual editor for ESPHome LVGL configs.",
  "author": "Andrea Ghidini <looptribe@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ghidosoft/esphome-lvgl-editor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghidosoft/esphome-lvgl-editor.git"
  },
  "bugs": {
    "url": "https://github.com/ghidosoft/esphome-lvgl-editor/issues"
  },
  "keywords": [
    "esphome",
    "lvgl",
    "preview",
    "editor",
    "yaml",
    "home-assistant",
    "embedded"
  ],
  "bin": {
    "esphome-lvgl-editor": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "samples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm run build"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "sirv": "^3.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/react-query": "^5.100.1",
    "@types/node": "^22.19.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "zod-validation-error": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
